  <body>

    <nav id="navbar">
      <header><h2>Resumo CSS</h2></header>
     <ul class="menu">
        <li><a class="nav-link" href="#CSS">CSS</a></li>
        <li><a class="nav-link" href="#Seletores">Seletores</a></li>
        <li><a class="nav-link" href="#Cascata">Cascata</a></li>
